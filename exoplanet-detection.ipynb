import numpy as np
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
import tensorflow as tf
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix
from sklearn.utils.class_weight import compute_class_weight
from tensorflow import keras
from tensorflow.keras import Input
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dropout, Dense, BatchNormalization
from tensorflow.keras.optimizers import Adam
from tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping

training = pd.read_csv("exoTrain.csv") # reads train csv
testing = pd.read_csv("exoTest.csv") # reads test csv
training['LABEL'] = training["LABEL"] - 1 #subtacts one from every label value
testing['LABEL'] = testing["LABEL"] - 1 #subtracts one from every label value
X = training.drop("LABEL", axis=1) # seaperates the features from the labels
Y = training["LABEL"] # seaperates the features from the labels

X_train, X_val, Y_train, Y_val = train_test_split( X, Y, test_size=0.4, random_state=5, stratify=Y) #splits the training and testing data
scaler = StandardScaler() #sales the data
X_train = scaler.fit_transform(X_train)
X_val = scaler.transform(X_val)

class_weights = compute_class_weight(class_weight='balanced', classes=np.unique(Y_train), y=Y_train) # helps manage the unbalanced data
class_weights = dict(enumerate(class_weights))
print("Class weights:", class_weights)

# builds the model
model=Sequential()
model.add(Input(shape=(3197,)))
model.add(Dense(512, activation='relu'))
model.add(BatchNormalization())
model.add(Dropout(0.2))
model.add(Dense(256, activation='relu'))
model.add(Dropout(0.2))
model.add(Dense(128, activation='relu'))
model.add(Dense(32, activation='relu'))
model.add(Dense(1, activation='sigmoid'))
model.summary()

# trains the model
model.compile(optimizer=Adam(learning_rate=0.001), loss='binary_crossentropy', metrics=['accuracy'])
checkpoint = ModelCheckpoint('best_model.keras', monitor='val_loss', save_best_only=True, mode='min', verbose=1)
early_stop = EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True, verbose=1)
history = model.fit(X_train, Y_train, validation_data=(X_val, Y_val), epochs=40, batch_size=64, class_weight=class_weights, callbacks=[checkpoint, early_stop])
best_model = keras.models.load_model('best_model.keras') #gets the best model from the epochs

X_testing = testing.drop("LABEL", axis=1) #prepare test data
y_testing = testing["LABEL"] #prepare test data
X_testing = scaler.transform(X_testing)

probs = best_model.predict(X_testing) #uses best model to evlauate exoTest csv
threshold = 0.3
preds = (probs > threshold).astype(int) # because we are using a sigmoid activation function

print("\nTensorFlow Neural Network Results:")
print("Accuracy:", accuracy_score(y_testing, preds))

print("\nClassification Report:")
print(classification_report(y_testing, preds, zero_division=0))

plt.plot(history.history['accuracy'], label='Train Accuracy') #training accuracy
plt.plot(history.history['val_accuracy'], label='Validation Accuracy')
plt.xlabel("Epochs")
plt.ylabel("Accuracy")
plt.title("Model Accuracy")
plt.legend()
plt.grid()
plt.show()

plt.plot(history.history['loss'], label='Train Loss') #training loss
plt.plot(history.history['val_loss'], label='Validation Loss')
plt.xlabel("Epochs")
plt.ylabel("Loss")
plt.title("Model Loss")
plt.legend()
plt.grid()
plt.show()

cm = confusion_matrix(y_testing, preds) #confusion matrix
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot=True, fmt='d', cmap='Reds')
plt.title("Confusion Matrix")
plt.xlabel("Predicted labels")
plt.ylabel("True labels")
plt.show()
